# Canonical site URL (no trailing path).
PUBLIC_SITE_URL=https://modafarshouha.github.io

# GitHub project pages: repository name only (no slashes).
# Use this instead of PUBLIC_BASE_PATH on Windows Git Bash — see docs/PUBLISHING.md.
PUBLIC_PAGES_SUBPATH=sloth_blog

# Alternative to PUBLIC_PAGES_SUBPATH (Unix CI / PowerShell): full base path, e.g. /my-repo/
# PUBLIC_BASE_PATH=/

# Optional: per-post read counts (see docs/ANALYTICS.md)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
