---
import { AUTHOR_NAME, AUTHOR_URL, SITE_TITLE } from '../consts';

interface Props {
	type?: 'website' | 'article';
	title: string;
	description: string;
	canonicalURL: URL | string;
	imageURL?: URL | string;
	publishedDate?: Date;
	updatedDate?: Date;
}

const { type = 'website', title, description, canonicalURL, imageURL, publishedDate, updatedDate } = Astro.props;

const url = canonicalURL.toString();
const siteRoot = new URL(import.meta.env.BASE_URL, Astro.site ?? 'https://modafarshouha.github.io/').toString();

const person = {
	'@type': 'Person',
	name: AUTHOR_NAME,
	url: AUTHOR_URL,
	sameAs: [AUTHOR_URL],
};

let schema: Record<string, unknown>;

if (type === 'article') {
	schema = {
		'@context': 'https://schema.org',
		'@type': 'BlogPosting',
		headline: title,
		description,
		mainEntityOfPage: { '@type': 'WebPage', '@id': url },
		url,
		datePublished: publishedDate ? publishedDate.toISOString() : undefined,
		dateModified: (updatedDate ?? publishedDate) ? (updatedDate ?? publishedDate)!.toISOString() : undefined,
		author: person,
		publisher: person,
		...(imageURL ? { image: imageURL.toString() } : {}),
	};
} else {
	schema = {
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		description,
		url: siteRoot,
		author: person,
		publisher: person,
	};
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
