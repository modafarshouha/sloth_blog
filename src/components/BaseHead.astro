---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { AUTHOR_NAME, SITE_TITLE } from '../consts';
import { withBase } from '../utils/path';
import JsonLd from './JsonLd.astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	type?: 'website' | 'article';
	publishedDate?: Date;
	updatedDate?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image, type = 'website', publishedDate, updatedDate } = Astro.props;

const imageURL = image ? new URL(image.src, Astro.url) : undefined;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
<link rel="sitemap" href={withBase('sitemap-index.xml')} />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL(withBase('rss.xml'), Astro.site)} />
<meta name="generator" content={Astro.generator} />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={AUTHOR_NAME} />
<meta name="robots" content="index, follow, max-image-preview:large" />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="en_US" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{imageURL && <meta property="og:image" content={imageURL} />}
{type === 'article' && publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
{type === 'article' && (updatedDate ?? publishedDate) && <meta property="article:modified_time" content={(updatedDate ?? publishedDate)!.toISOString()} />}
{type === 'article' && <meta property="article:author" content={AUTHOR_NAME} />}

<meta property="twitter:card" content={imageURL ? 'summary_large_image' : 'summary'} />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{imageURL && <meta property="twitter:image" content={imageURL} />}

<JsonLd
	type={type}
	title={title}
	description={description}
	canonicalURL={canonicalURL}
	imageURL={imageURL}
	publishedDate={publishedDate}
	updatedDate={updatedDate}
/>
