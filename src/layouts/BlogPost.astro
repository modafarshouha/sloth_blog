---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PostReadStats from '../components/PostReadStats.astro';
import CitationBlock from '../components/CitationBlock.astro';

type Props = CollectionEntry<'blog'>['data'] & { postSlug?: string };

const { title, description, pubDate, updatedDate, heroImage, postSlug } = Astro.props;
const postUrl = postSlug ? new URL(`blog/${postSlug}/`, Astro.site ?? 'https://modafarshouha.github.io/sloth_blog/').href : '';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage ?? undefined} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding-top: 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				max-height: 22rem;
				object-fit: cover;
			}
			.prose {
				width: 40rem;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 0 1rem 2rem;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1.25rem;
				padding-top: 1.5rem;
			}
			.title h1 {
				margin: 0 0 0.35rem;
				font-size: 2rem;
			}
			.date {
				margin: 0 0 0.5rem;
				color: rgb(var(--muted));
				font-size: 0.95rem;
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Updated <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{postSlug && <PostReadStats slug={postSlug} />}
						<hr />
					</div>
					<slot />
					{postSlug && <CitationBlock title={title} date={pubDate} url={postUrl} />}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
